{
  "name": "filelink-nextcloud",
  "version": "3.14.0",
  "description": "*cloud - FileLink for Nextcloud and ownCloud",
  "dependencies": {
    "punycode": "^2.1.1"
  },
  "scripts": {
    "test": "npx web-ext run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/joendres/filelink-nextcloud.git"
  },
  "keywords": [
    "thunderbird",
    "filelink",
    "cloudfile",
    "owncloud",
    "nextcloud"
  ],
  "author": {
    "name": "Johannes Endres",
    "email": "je@johannes-endres.de",
    "url": "https: //gitlab.com/joendres"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://gitlab.com/joendres/filelink-nextcloud/issues",
    "email": "cloud@johannes-endres.de"
  },
  "homepage": "https://joendres.gitlab.io/filelink-nextcloud/",
  "devDependencies": {
    "@types/firefox-webext-browser": "^70",
    "glob": "^8.0.3",
    "jshint": "^2.13.5",
    "thunderbird-web-ext-types": "^1.0.0",
    "web-ext": "latest"
  },
  "private": true,
  "files": [
    "./src"
  ],
  "webExt": {
    "ignoreFiles": [
      "punycode/package.json",
      "punycode/README.md",
      "punycode/punycode.es6.js",
      "punycode/scripts",
      "punycode/tests",
      "photon-components-web/index.js",
      "photon-components-web/images/arrow-grey-40-*.svg",
      "photon-components-web/images/open-in-new-16-*.svg",
      "photon-components-web/images/searchfield-cancel-*.svg"
    ],
    "sourceDir": "src",
    "run": {
      "browserConsole": true
    },
    "build": {
      "overwriteDest": true
    }
  }
}
{
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/thunderbird-webext-browser": "*",
    "eslint": "^10.7.0",
    "globals": "*",
    "jsdom": "^26.1.0",
    "web-ext": "^7.12.0"
  },
  "private": true,
  "scripts": {
    "start": "npx web-ext run"
  },
  "webExt": {
    "ignoreFiles": [
      "photon-components-web/index.js",
      "photon-components-web/images/arrow-grey-40-*.svg",
      "photon-components-web/images/open-in-new-16-*.svg",
      "photon-components-web/images/searchfield-cancel-*.svg",
      "**/*.license"
    ],
    "sourceDir": "src",
    "noInput": true,
    "run": {
      "firefox": "thunderbird/thunderbird",
      "firefoxProfile": "thunderbird/profile-for-debugging/",
      "devtools": true
    },
    "build": {
      "overwriteDest": true
    },
    "lint": {
      "selfHosted": true
    },
    "sign": {
      "channel": "listed",
      "apiUrlPrefix": "https://addons.thunderbird.net/api/v4"
    }
  }
}
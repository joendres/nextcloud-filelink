{
    "bitwise": true,
    "curly": true,
    "eqeqeq": true,
    "esversion": 9,
    "futurehostile": true,
    "latedef": "nofunc",
    "leanswitch": true,
    "maxcomplexity": 10,
    "maxdepth": 3,
    "nocomma": true,
    "nonew": true,
    "predef": [
        "browser"
    ],
    "shadow": "outer",
    "singleGroups": false,
    "strict": "implied",
    "trailingcomma": true,
    "undef": true,
    "unused": true,
    "varstmt": true,
    "moz": true,
    "browser": true,
    "module": true
}
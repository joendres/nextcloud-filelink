{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run with web-ext",
            "type": "shell",
            "command": [
                "${workspaceFolder}/node_modules/.bin/web-ext run -s ${workspaceFolder}/src"
            ],
            "presentation": {
                "echo": false,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "close": true
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Run unit tests in Thunderbird",
            "type": "shell",
            "command": [
                "${workspaceFolder}/node_modules/.bin/web-ext run -s ${workspaceFolder}"
            ],
            "presentation": {
                "echo": false,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "close": true
            }
        }
    }
]
}
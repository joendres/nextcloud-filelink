{
    "cSpell.ignorePaths": [
        "node_modules",
        "package.json"
    ],
    "cSpell.words": [
        "ADFS",
        "Anhangsordners",
        "anhängte",
        "Benachrichtigungsleiste",
        "Bynens",
        "closebtn",
        "clouduploader",
        "Comunicaciones",
        "davuploader",
        "joendres",
        "MKCOL",
        "mtimes",
        "Nextcloud",
        "tbversionworkarounds",
        "Uploader",
        "webdav"
    ],
    "cSpell.language": "de,en",
    "cSpell.allowCompoundWords": true,
    "git.fetchOnPull": true,
    "git.untrackedChanges": "separate",
    "todo-tree.filtering.excludeGlobs": [
        "**/node_modules",
        "**/photon-components-web/index.css"
    ]
}